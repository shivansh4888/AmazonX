# Database
DATABASE_URL="postgresql://username:password@localhost:5432/ecommerce_db"

# Server
PORT=5000
NODE_ENV=development

# Email Configuration (Nodemailer)
# Option 1: Gmail SMTP (use App Password, not regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="ShopX Store <your-email@gmail.com>"

# Option 2: Ethereal (for testing - auto-generated)
# Leave EMAIL_USER and EMAIL_PASS empty to auto-create Ethereal test account

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
