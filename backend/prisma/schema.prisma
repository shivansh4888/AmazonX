// Prisma Schema for E-Commerce Application
// Defines all database models and relationships

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                 String                     @id @default(uuid())
  name               String
  description        String
  price              Float
  stock              Int                        @default(0)
  category           String
  images             String[]                   // Array of image URLs
  specs              Json?                      // Key-value specs object
  rating             Float                      @default(4.0)
  reviewCount        Int                        @default(0)
  brand              String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  cartItems          CartItem[]
  orderItems         OrderItem[]
  reviews            Review[]
  priceHistory       PriceHistory[]
  compatibilityRules ProductCompatibilityRule[]
  purchaseHistory    PurchaseHistory[]
  challenges         Challenge[]
  coupons            Coupon[]
  @@index([category])
  @@index([name])
}

model Cart {
  id                String   @id @default(uuid())
  sessionId         String   @unique // Browser session ID (no auth required)
  items             CartItem[]
  appliedCouponCode String?
  appliedCoupon     Coupon?  @relation("AppliedCouponCarts", fields: [appliedCouponCode], references: [code])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
}

model Order {
  id                String        @id @default(uuid())
  status            OrderStatus   @default(CONFIRMED)
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus @default(PAID)
  subtotal          Float
  discount          Float         @default(0)
  tax               Float
  shippingCost      Float         @default(0)
  total             Float
  couponCode        String?
  // Shipping address stored as JSON
  shippingAddress   Json
  // Customer email for notifications
  customerEmail     String
  customerName      String
  estimatedDelivery DateTime
  items             OrderItem[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([customerEmail])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  price     Float   // Price at time of purchase (snapshot)
  name      String  // Product name snapshot

  @@index([orderId])
}

model Review {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  email     String   // purchaser's email
  name      String
  rating    Int      // 1–5
  title     String
  body      String
  createdAt DateTime @default(now())

  @@unique([productId, email])
  @@index([productId])
}

model ProductCompatibilityRule {
  id                      String   @id @default(uuid())
  category                String
  requires                String[]
  minCompatiblePriceRatio Float?
  warningMessage          String
  severity                String   @default("medium")
  product                 Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId               String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([category])
  @@index([productId])
}

model PriceHistory {
  id         String   @id @default(uuid())
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  price       Float
  timestamp   DateTime @default(now())

  @@index([productId, timestamp])
}

model PurchaseHistory {
  id         String   @id @default(uuid())
  userId     String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  quantity   Int
  timestamp  DateTime @default(now())

  @@index([userId, productId, timestamp])
}

model Challenge {
  id              String             @id @default(uuid())
  product         Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String
  type            ChallengeType
  prompt          String
  answer          String
  discountPercent Float
  attempts        ChallengeAttempt[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([productId])
}

model ChallengeAttempt {
  id         String    @id @default(uuid())
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  challengeId String
  userId      String
  answer      String
  isCorrect   Boolean
  couponCode  String?
  createdAt   DateTime  @default(now())

  @@index([challengeId, userId])
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  userId          String
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId       String?
  discountPercent Float
  expiresAt       DateTime
  redeemedAt      DateTime?
  createdAt       DateTime @default(now())
  carts           Cart[]   @relation("AppliedCouponCarts")

  @@index([userId, expiresAt])
  @@index([productId])
}

enum OrderStatus {
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CARD
  UPI
  COD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ChallengeType {
  QUIZ
  PUZZLE
}
